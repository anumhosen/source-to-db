{
  "name": "repodocs-electron",
  "version": "1.0.0",
  "description": "RepoDocs - Code Repository Documentation Tool",
  "license": "MIT",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:unpack": "electron-builder --dir",
    "build:pack": "electron-builder --prepackaged release/win-unpacked",
    "postinstall": "electron-builder install-app-deps",
    "build-icon": "node scripts/generate-icons.js"
  },
  "repository": "https://github.com/anumhosen/source-to-db",
  "keywords": [
    "Electron",
    "source",
    "code",
    "repository",
    "documentation",
    "tool"
  ],
  "author": {
    "name": "Anum Hosen",
    "email": "anumhosen@gmail.com"
  },
  "build": {
    "appId": "com.repodocs.app",
    "productName": "RepoDocs",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend/**/*",
      "ipc/**/*",
      "dist/**/*",
      "assets/**/*",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/docs",
      "!node_modules/**/test",
      "!node_modules/**/tests",
      "!node_modules/**/example",
      "!node_modules/**/examples",
      "!node_modules/**/.bin"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-llama-cpp/**"
    ],
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "sign": null
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "deb",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "better-sqlite3": "11.3.0",
    "simple-git": "3.25.0",
    "node-llama-cpp": "3.18.1",
    "cross-env": "7.0.3"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "25.1.7",
    "electron-rebuild": "3.2.9"
  }
}
